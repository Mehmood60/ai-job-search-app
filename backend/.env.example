# Backend local-dev environment. Copy to backend/.env
PORT=4000
NODE_ENV=development

# "json" (default) or "postgres"
DB_DRIVER=json
JSON_DB_PATH=data/db.json
DATABASE_URL=postgresql://appuser:apppass@localhost:5432/aijobsearch?schema=public

# CHANGE THESE — generate with: openssl rand -hex 32
JWT_SECRET=dev-jwt-secret-change-me-0000000000000000
APP_SECRET=dev-app-secret-change-me-0000000000000000

CORS_ORIGIN=http://localhost:5173

# Optional: point Puppeteer at a system Chromium instead of the bundled one
# PUPPETEER_EXECUTABLE_PATH=
