# ─────────────────────────────────────────────────────────────
# ai-job-search-app — root environment example
# Copy to .env for docker-compose, and to backend/.env for local dev.
# ─────────────────────────────────────────────────────────────

# Backend
PORT=4000
NODE_ENV=development

# Data layer: "json" (default, file-based) or "postgres"
DB_DRIVER=json
# JSON store location (relative to backend/) — used when DB_DRIVER=json
JSON_DB_PATH=data/db.json
# Postgres connection — used when DB_DRIVER=postgres
DATABASE_URL=postgresql://appuser:apppass@postgres:5432/aijobsearch?schema=public

# Secrets — CHANGE THESE. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-please-32-bytes-minimum-secret
APP_SECRET=change-me-too-32-byte-key-for-encryption

# CORS origin for the frontend (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:5173

# Optional: build the backend image with a full LaTeX toolchain (heavy).
# Set at build time: docker build --build-arg WITH_LATEX=true
WITH_LATEX=false

# Puppeteer: in Docker we use system Chromium. Locally leave unset to auto-download.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Frontend (Vite) — base URL of the backend API
VITE_API_BASE_URL=http://localhost:4000
