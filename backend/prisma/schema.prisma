// Prisma schema — used only when DB_DRIVER=postgres.
// Profile/Settings are stored as JSON blobs to mirror the JSON store shape.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("users")
}

model Profile {
  userId    String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

model Settings {
  userId    String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("settings")
}
